# ==============================================================================
# Kubernetes Secret Template for Gemini API Key
# Copy this file to 'secrets.yaml', replace the base64 placeholder, and apply it.
# Note: To base64 encode your API key on Linux/macOS: echo -n "YOUR_KEY" | base64
#       To base64 encode on Windows PowerShell: [Convert]::ToBase64String([System.Text.Encoding]::UTF8.GetBytes("YOUR_KEY"))
# ==============================================================================
apiVersion: v1
kind: Secret
metadata:
  name: gemini-secrets
  namespace: theme-based-rag-workflow-jiragraph
type: Opaque
data:
  # Base64 encoded value of your GEMINI_API_KEY
  gemini-api-key: REPLACE_WITH_BASE64_ENCODED_GEMINI_API_KEY
